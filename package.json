{
  "name": "supa-next-starter",
  "description": "A production ready Next.js/Supabase starter. ",
  "version": "1.0.0",
  "private": true,
  "author": "Michael Troya <hi@michaeltroya.ca> (@michaeltroya)",
  "license": "MIT",
  "keywords": [
    "nextjs",
    "starter",
    "supabase",
    "tailwindcss",
    "shadcn",
    "typescript"
  ],
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "knip": "knip",
    "knip:production": "knip --production --config knip.production.json",
    "format": "prettier --write .",
    "format-check": "prettier --check .",
    "type-check": "next typegen && tsc --pretty --noEmit",
    "prepare": "husky install || true",
    "test": "jest",
    "test:ci": "jest --ci",
    "test:database-contract": "jest --ci --runInBand src/lib/server/databaseContract.test.ts",
    "audit:security": "pnpm audit --audit-level high",
    "analyze": "ANALYZE=true pnpm build",
    "fix-deps": "./scripts/fix-deps.sh",
    "fix-all-deps": "./scripts/fix-all-deps.sh",
    "clean": "rm -rf .next node_modules/.cache",
    "install-safe": "corepack use pnpm@9.15.2 && pnpm install --frozen-lockfile"
  },
  "dependencies": {
    "@material-tailwind/react": "^2.1.10",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "@types/node": "20.3.1",
    "@types/react": "18.2.8",
    "@types/react-dom": "18.2.5",
    "autoprefixer": "10.4.15",
    "clsx": "^2.1.0",
    "geist": "^1.2.0",
    "lucide-react": "^1.18.0",
    "next": "15.5.18",
    "next-themes": "^0.2.1",
    "nextjs-toploader": "^1.6.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwind-merge": "^2.2.0",
    "tailwindcss": "3.3.3",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "5.1.3"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.5.18",
    "@swc/core": "^1.3.102",
    "@swc/jest": "^0.2.29",
    "@testing-library/dom": "^9.3.3",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.11",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.18",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "knip": "^6.16.1",
    "lint-staged": "^15.2.0",
    "postcss": "8.5.15",
    "prettier": "^3.1.1",
    "prettier-plugin-tailwindcss": "^0.5.10",
    "supabase": "^2.48.3"
  },
  "pnpm": {
    "overrides": {
      "@typescript-eslint/parser": "8.61.0"
    }
  },
  "packageManager": "pnpm@9.15.2+sha256.022309bb31359142b65bfa889e0406d2eebd5acfffca47e6944acf29d9d6a66b"
}
